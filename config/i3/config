# =============================================================================
# i3wm Config - Quân (DevOps Edition)
# Mục tiêu: Hiện đại - Dịu mắt (Everforest Soft) - Hiệu suất cao
# =============================================================================

set $mod Mod1

# --- 1. GIAO DIỆN & FONT (Bảo vệ mắt) ---
font pango:JetBrainsMono Nerd Font 11
gaps inner 12
gaps outer 5
smart_gaps on
default_border pixel 2
default_floating_border pixel 2
floating_modifier $mod

# --- 2. BẢNG MÀU EVERFOREST SOFT ---
set $bg      #2d353b
set $fg      #d3c6aa
set $green   #a7c080
set $yellow  #dbbc7f
set $red     #e67e80
set $grey    #859289
set $bg_alt  #343f44

client.focused          $green    $bg_alt   $fg     $green    $green
client.unfocused        $bg       $bg       $grey   $bg       $bg
client.focused_inactive $bg       $bg       $grey   $bg       $bg
client.urgent           $red      $red      $bg     $red      $red

# --- 3. TỰ ĐỘNG CHẠY (Autostart) ---
# Dọn dẹp thanh bar cũ và chạy Polybar mới
exec_always --no-startup-id killall -q i3bar i3status polybar
exec_always --no-startup-id polybar top &
# Hiệu ứng bo tròn góc & đổ bóng
exec_always --no-startup-id picom --backend glx --vsync --corner-radius 10 --shadow --shadow-radius 12 --shadow-opacity 0.4 -b

# Xóa dòng redshift cũ đi, thay bằng dòng "vàng trắng" chuẩn này:
exec --no-startup-id pkill redshift; redshift -l 10.82:106.63 -t 5700:4000 -b 1.0:0.8

# Tiện ích hệ thống
exec --no-startup-id nm-applet
exec --no-startup-id fcitx5 -d
exec_always --no-startup-id setxkbmap -option caps:escape

# --- 4. PHÍM TẮT CƠ BẢN ---
bindsym $mod+Return exec alacritty
bindsym $mod+Shift+q kill
# Thay thế dmenu bằng rofi
bindsym $mod+d exec --no-startup-id rofi -show drun -show-icons

# --- DÒNG QUAN TRỌNG: CHỤP ẢNH MÀN HÌNH ---
bindsym Print exec --no-startup-id flameshot gui

# --- 5. WORKFLOW DEVOPS (Phím tắt nhanh) ---
bindsym $mod+Shift+b exec alacritty -e btop
bindsym $mod+Shift+g exec alacritty -e lazygit
bindsym $mod+Shift+d exec alacritty -e ctop
# Mở Menu Nguồn (Logout/Reboot/Shutdown) - Nhớ tạo file .sh mình gửi trước đó nhé
bindsym $mod+Shift+x exec --no-startup-id ~/.config/rofi/powermenu.sh

# --- 6. WORKSPACES (10 Workspaces cho đa nhiệm) ---
set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
set $ws10 "10"

bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number $ws6
bindsym $mod+7 workspace number $ws7
bindsym $mod+8 workspace number $ws8
bindsym $mod+9 workspace number $ws9
bindsym $mod+0 workspace number $ws10

bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3
bindsym $mod+Shift+4 move container to workspace number $ws4
bindsym $mod+Shift+5 move container to workspace number $ws5
bindsym $mod+Shift+6 move container to workspace number $ws6
bindsym $mod+Shift+7 move container to workspace number $ws7
bindsym $mod+Shift+8 move container to workspace number $ws8
bindsym $mod+Shift+9 move container to workspace number $ws9
bindsym $mod+Shift+0 move container to workspace number $ws10

# --- 7. ĐIỀU HƯỚNG & DI CHUYỂN CHUẨN VIM (h j k l) ---

# 1. Di chuyển tiêu điểm (Chỉ di chuyển mắt nhìn)
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right

# 2. DI CHUYỂN CỬA SỔ (Nhấc cửa sổ vứt đi chỗ khác)
# Chèn đống này vào đây:
bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right
# Các phím hệ thống giữ nguyên
bindsym $mod+Shift+c reload
bindsym $mod+Shift+r restart

# Tự động floating cho các cửa sổ nhỏ
for_window [window_role="pop-up"] floating enable
for_window [window_role="task_dialog"] floating enable
for_window [class="Gsimplecal"] floating enable
# Giết bar cũ và chạy Polybar 'top' ngầm (&)
# 1. Khởi động Polybar và ép nó ẩn đi ngay lập tức
exec_always --no-startup-id "killall -q polybar; polybar top & sleep 1; polybar-msg cmd hide"

# 2. Phím tắt để gọi thanh bar (Nhấn Mod+b để hiện, nhấn lại để ẩn)
bindsym $mod+b exec --no-startup-id polybar-msg cmd toggle
# Giúp bảng WiFi và Lịch hiện lên dạng pop-up nhỏ gọn
for_window [class="Nm-connection-editor"] floating enable, border pixel 2, sticky enable
for_window [class="Gsimplecal"] floating enable, border pixel 2, sticky enable
# Khởi động dịch vụ lưu trữ mật khẩu (Keyring)
exec --no-startup-id /usr/bin/gnome-keyring-daemon --start --components=pkcs11,secrets,ssh
exec --no-startup-id dbus-update-activation-environment --all
# --- 8. CHẾ ĐỘ RESIZE CHUẨN VIM ---
bindsym $mod+r mode "resize"

mode "resize" {
        # h: Thu hẹp chiều ngang (sang trái)
        bindsym h resize shrink width 10 px or 10 ppt
        # j: Mở rộng chiều cao (xuống dưới)
        bindsym j resize grow height 10 px or 10 ppt
        # k: Thu hẹp chiều cao (lên trên)
        bindsym k resize shrink height 10 px or 10 ppt
        # l: Mở rộng chiều ngang (sang phải)
        bindsym l resize grow width 10 px or 10 ppt

        # Thoát chế độ
        bindsym Return mode "default"
        bindsym Escape mode "default"
}
# --- 9. LAYOUT & CHẾ ĐỘ HIỂN THỊ (Bổ sung cho Quân) ---
# Toàn màn hình
bindsym $mod+f fullscreen toggle

# Thay đổi kiểu sắp xếp cửa sổ
bindsym $mod+s layout stacking
bindsym $mod+w layout tabbed
bindsym $mod+e layout toggle split

# Chuyển đổi qua lại giữa Tiling (lát gạch) và Floating (nổi)
bindsym $mod+Shift+space floating toggle

# Chuyển tiêu điểm giữa cửa sổ nổi và cửa sổ gạch
bindsym $mod+space focus mode_toggle

# Chọn container cha (hữu ích khi muốn move cả cụm cửa sổ)
bindsym $mod+a focus parent
# --- BỔ SUNG VÀO PHẦN 9 ---
# Chia theo chiều ngang (cửa sổ mới sẽ nằm bên phải)
bindsym $mod+g split h
# Chia theo chiều dọc (cửa sổ mới sẽ nằm bên dưới)
bindsym $mod+v split v

# Đổi border pixel 0 thành border pixel 2 để tạo viền
for_window [class="study_timer"] floating enable, sticky enable, border pixel 0, resize set 170 55, move window to position 15 1010

# Phím tắt gọi Script Toggle
bindsym $mod+Shift+t exec ~/.config/i3/toggle_timer.sh
